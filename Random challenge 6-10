#Random challenge6
#write some code that is like a dice
#the code says "spacebar to roll or...
#...press x to exit"
#You press the spacebar then enter..
#It generates a number between 1 and 6
#Then asks you the question again...
#until you press "x" then enter and it stops

import random

while True:
    user_input = input("Press SPACE then ENTER to roll, or 'x' then ENTER to exit: ")

    if user_input.lower() == "x":
        print("Goodbye!")
        break
    elif user_input == " ":
        roll = random.randint(1, 6)
        print(f"You rolled: {roll}")
    else:
        print("Invalid input. Press SPACE or 'x'.")


#Random challenge8
#Create a "guess the number" game
#Where a random number between...
#..1 to 5 is generated and stored
#The user must guess the number
#If the user guesses too high, "too high" is displayed
#If the user guesses too low, "too low" is displayed
#while the number isn’t guessed, a user must guess
#when the number is guessed a message is displayed
#"it took you x times to guess"
#where x is the number if user guesses


import random

# Generate a random number between 1 and 5
number = random.randint(1, 5)

guess = None
attempts = 0

while guess != number:
    guess = int(input("Guess a number between 1 and 5: "))
    attempts += 1

    if guess > number:
        print("Too high")
    elif guess < number:
        print("Too low")

print(f"It took you {attempts} times to guess!")

